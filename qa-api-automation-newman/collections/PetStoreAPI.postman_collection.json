      "name": "Smoke Tests",
      "item": [
        {
          "name": "TC-01: Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is valid JSON', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Response contains pet data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Response has correct Content-Type header', function() {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('The id field is a number', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('The name field is a string', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('The status field is a string with a valid value', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.be.a('string');",
                  "    pm.expect(['available', 'pending', 'sold']).to.include(jsonData.status);",
                  "});",
                  "",
                  "pm.test('The category object has id and name properties', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.category).to.be.an('object');",
                  "    pm.expect(jsonData.category).to.have.property('id');",
                  "    pm.expect(jsonData.category).to.have.property('name');",
                  "});",
                  "",
                  "pm.test('The photoUrls field is an array', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.photoUrls).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('The tags field is an array', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.tags).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pet",
                "1"
              ]
            },
            "description": "Basic health check endpoint to verify API is responding"
          },
          "response": []
        },
